@model ASPNET_DK24TT8017_hoangphongphuc_DIENDANTINHOC.Models.ProjectTopic

@{
    ViewData["Title"] = "Đề xuất Đề tài mới";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card card-premium text-white">
                <div class="card-header bg-dark-trans border-0 pt-4 px-4">
                    <h3 class="card-title mb-0"><i class="bi bi-file-earmark-plus me-2 text-info"></i>Đề xuất Đề tài Đồ án mới</h3>
                    <p class="text-muted mb-0 small">Giảng viên đề xuất đề tài cho sinh viên đăng ký thực hiện</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label font-weight-bold">Tên đề tài</label>
                            <input asp-for="Title" class="form-control form-input" placeholder="Ví dụ: Nghiên cứu thị giác máy tính trong nhận diện khuôn mặt..." required />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Category" class="form-label font-weight-bold">Chủ đề phân loại</label>
                            <select asp-for="Category" class="form-select form-input">
                                <option value="AI">AI (Trí tuệ nhân tạo)</option>
                                <option value="Phần cứng">Phần cứng (Hardware / IoT)</option>
                                <option value="Phần mềm">Phần mềm (Software / Web)</option>
                            </select>
                            <span asp-validation-for="Category" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label font-weight-bold">Mô tả đề tài & Yêu cầu kỹ thuật</label>
                            <textarea asp-for="Description" rows="6" class="form-control form-input" placeholder="Mô tả chi tiết mục tiêu, công nghệ sử dụng và các kết quả mong đợi..." required></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
                            <button type="submit" class="btn btn-primary btn-glow px-4">Đăng đề tài</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
