@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Hero Section -->
<div class="hero-section text-center py-5 mb-5 rounded card-premium position-relative overflow-hidden">
    <div class="hero-bg-overlay"></div>
    <div class="position-relative z-1 py-4 px-3">
        <h1 class="display-3 font-weight-extrabold text-glow-light mb-3">Học tập & Sáng tạo Công nghệ</h1>
        <p class="lead text-light-muted mb-4 max-w-600 mx-auto fs-4">
            Hệ thống diễn đàn học thuật, chia sẻ kiến thức tin học và quản lý đồ án chuyên nghiệp khoa Công nghệ thông tin.
        </p>
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a asp-controller="Account" asp-action="Profile" class="btn btn-primary btn-glow px-4 py-2 rounded-pill font-weight-bold">
                    <i class="bi bi-person-fill"></i> Vào trang cá nhân của bạn
                </a>
                <a asp-controller="Forum" asp-action="Index" class="btn btn-outline-info px-4 py-2 rounded-pill font-weight-bold">
                    <i class="bi bi-chat-dots-fill"></i> Thảo luận diễn đàn
                </a>
            </div>
        }
        else
        {
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-glow px-4 py-2 rounded-pill font-weight-bold">
                    Đăng nhập ngay
                </a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-info px-4 py-2 rounded-pill font-weight-bold">
                    Đăng ký tài khoản
                </a>
            </div>
        }
    </div>
</div>

<!-- Features Section -->
<div class="row mb-5">
    <div class="col-md-4 mb-4">
        <div class="card card-premium text-white h-100 text-center py-4 px-3 card-hover-translate">
            <div class="card-body">
                <div class="icon-circle bg-info-trans text-info mx-auto mb-4">
                    <i class="bi bi-chat-left-text-fill fs-2"></i>
                </div>
                <h4 class="font-weight-bold text-light-blue mb-3">Diễn đàn Tin học</h4>
                <p class="text-light-muted small">
                    Đăng bài viết chia sẻ kinh nghiệm, thảo luận các chủ đề nóng về Trí tuệ nhân tạo (AI), Thiết kế Phần cứng và Phát triển Phần mềm.
                </p>
                <a asp-controller="Forum" asp-action="Index" class="btn btn-sm btn-outline-info mt-3 btn-glow">Khám phá ngay</a>
            </div>
        </div>
    </div>
    
    <div class="col-md-4 mb-4">
        <div class="card card-premium text-white h-100 text-center py-4 px-3 card-hover-translate">
            <div class="card-body">
                <div class="icon-circle bg-purple-trans text-purple mx-auto mb-4">
                    <i class="bi bi-journal-code fs-2"></i>
                </div>
                <h4 class="font-weight-bold text-light-blue mb-3">Quản lý Đề tài</h4>
                <p class="text-light-muted small">
                    Sinh viên đăng ký các đề tài đồ án chuyên đề, giảng viên theo dõi danh sách sinh viên hướng dẫn và kiểm duyệt đề tài nhanh chóng.
                </p>
                <a asp-controller="Project" asp-action="Index" class="btn btn-sm btn-outline-info mt-3 btn-glow">Xem đề tài</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card card-premium text-white h-100 text-center py-4 px-3 card-hover-translate">
            <div class="card-body">
                <div class="icon-circle bg-success-trans text-success mx-auto mb-4">
                    <i class="bi bi-graph-up-arrow fs-2"></i>
                </div>
                <h4 class="font-weight-bold text-light-blue mb-3">Mốc Tiến độ & GitHub</h4>
                <p class="text-light-muted small">
                    Tự động tạo các mốc tiến độ cụ thể. Sinh viên nộp bài qua liên kết GitHub Repository, giảng viên đánh giá trực tiếp trên hệ thống.
                </p>
                <a asp-controller="Account" asp-action="Profile" class="btn btn-sm btn-outline-info mt-3 btn-glow">Theo dõi tiến độ</a>
            </div>
        </div>
    </div>
</div>

