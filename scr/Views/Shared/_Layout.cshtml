<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Diễn đàn Tin học & Quản lý Đồ án</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Google Fonts: Outfit -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ASPNET_DK24TT8017_hoangphongphuc_DIENDANTINHOC.styles.css" asp-append-version="true" />
</head>
<body class="bg-premium-dark text-white">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-glass border-bottom-trans mb-4 py-3 sticky-top">
            <div class="container">
                <a class="navbar-brand font-weight-extrabold text-glow d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-cpu-fill text-info me-2 fs-4"></i>
                    <span>DIỄN ĐÀN TIN HỌC & ĐỒ ÁN</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door-fill me-1"></i> Trang chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-controller="Forum" asp-action="Index">
                                <i class="bi bi-chat-left-text-fill me-1"></i> Diễn đàn Tin học
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-controller="Project" asp-action="Index">
                                <i class="bi bi-journal-code me-1"></i> Đề tài Đồ án
                            </a>
                        </li>
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                            var roleBadge = role == "SinhVien" ? "Sinh viên" : (role == "Admin" ? "Admin" : "Giảng viên");
                            
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle nav-link-custom d-flex align-items-center bg-dark-trans px-3 py-2 rounded-pill" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="avatar-nav rounded-circle bg-info d-flex align-items-center justify-content-center text-white me-2" style="width: 28px; height: 28px; font-weight: bold; font-size: 0.8rem;">
                                        @User.Identity.Name?.Substring(0, Math.Min(1, User.Identity.Name.Length)).ToUpper()
                                    </div>
                                    <span>@User.Identity.Name</span>
                                    <span class="badge bg-secondary ms-2 small" style="font-size: 0.7rem;">@roleBadge</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end bg-glass border-secondary py-2 mt-2" aria-labelledby="navbarDropdown">
                                    <li>
                                        <a class="dropdown-item py-2" asp-controller="Account" asp-action="Profile">
                                            <i class="bi bi-person-fill me-2 text-info"></i> Hồ sơ cá nhân
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider border-secondary"></li>
                                    <li>
                                        <a class="dropdown-item py-2 text-danger" asp-controller="Account" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="nav-link nav-link-custom text-white" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary btn-glow px-4 py-2 rounded-pill text-white font-weight-bold" asp-controller="Account" asp-action="Register">
                                    Đăng ký
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container container-main">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-premium border-top-trans mt-auto py-4 text-center text-muted small bg-dark-trans">
        <div class="container">
            <p class="mb-1">&copy; 2026 - Đồ án Chuyên đề ASP.NET - Website Diễn đàn Tin học và Quản lý Đồ án</p>
            <p class="mb-0 text-light-muted">
                GVHD: <strong>Đoàn Phước Miền</strong> | SV thực hiện: <strong>Hoàng Phong Phúc</strong> (MSV: 170124447)
            </p>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
