@{
    ViewData["Title"] = "Đăng ký tài khoản";
}

<div class="auth-container">
    <div class="auth-card">
        <h2 class="auth-title">Đăng ký Tài khoản</h2>
        <p class="auth-subtitle">Tạo tài khoản mới cho sinh viên hoặc giảng viên</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <div asp-validation-summary="All" class="text-danger small"></div>
            </div>
        }

        <form asp-action="Register" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <div class="form-group mb-3">
                <label for="username" class="form-label">Tên đăng nhập (Username)</label>
                <input type="text" id="username" name="username" class="form-control form-input" placeholder="Ví dụ: phuc.hp" required />
            </div>

            <div class="form-group mb-3">
                <label for="fullName" class="form-label">Họ và tên</label>
                <input type="text" id="fullName" name="fullName" class="form-control form-input" placeholder="Ví dụ: Hoàng Phong Phúc" required />
            </div>

            <div class="form-group mb-3">
                <label for="email" class="form-label">Địa chỉ Email</label>
                <input type="email" id="email" name="email" class="form-control form-input" placeholder="Ví dụ: phuc.hp@school.vn" required />
            </div>

            <div class="form-group mb-3">
                <label for="password" class="form-label">Mật khẩu</label>
                <input type="password" id="password" name="password" class="form-control form-input" placeholder="Nhập mật khẩu bảo mật..." required />
            </div>

            <div class="form-group mb-4">
                <label for="role" class="form-label">Vai trò chức vụ</label>
                <select id="role" name="role" class="form-select form-input">
                    <option value="SinhVien">Sinh viên thực hiện đồ án</option>
                    <option value="GiangVien">Giảng viên hướng dẫn</option>
                </select>
            </div>

            <button type="submit" class="btn btn-primary w-100 btn-submit btn-glow">Đăng ký</button>
        </form>

        <div class="auth-footer mt-4">
            Đã có tài khoản? <a asp-action="Login" class="auth-link">Đăng nhập</a>
        </div>
    </div>
</div>
